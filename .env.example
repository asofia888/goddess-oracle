# Google Generative AI API Key
# Get your API key from: https://makersuite.google.com/app/apikey
# IMPORTANT: This should ONLY be set on the server side (Vercel environment variables)
GOOGLE_API_KEY=your_google_api_key_here

# Application Environment
NODE_ENV=production

# API Endpoint (automatically set by Vercel)
# VITE_API_ENDPOINT=/api

# Optional: Vercel URL (automatically set by Vercel in production)
# VERCEL_URL=your-app.vercel.app

# Optional: Custom allowed origins for CORS (comma-separated)
# Set this if you need to allow additional origins beyond the defaults
# ALLOWED_ORIGINS=https://your-custom-domain.com,https://another-domain.com

# Upstash Redis (for distributed rate limiting)
# Create a free database at: https://console.upstash.com/
# Without these, the app falls back to in-memory rate limiting (not suitable for production)
UPSTASH_REDIS_REST_URL=your_upstash_redis_rest_url_here
UPSTASH_REDIS_REST_TOKEN=your_upstash_redis_rest_token_here
